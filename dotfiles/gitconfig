[alias]
	co = checkout
	ci = commit
	st = status -s -b
	lg = log --pretty=format:\"%C(yellow)%h %C(cyan)%ad%Creset | [%an]%d%n%s%n\" --graph --date=short
	diff = diff --ignore-space-change
	difft = difftool -Y --ignore-space-change
	merget = mergetool -Y
	tracked = "!f() { git ls-files $1 --error-unmatch; }; f"
[push]
	default = current
